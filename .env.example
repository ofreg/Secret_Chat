POSTGRES_DB=app_db
POSTGRES_USER=app_user
POSTGRES_PASSWORD=app_pass
POSTGRES_HOST=db
POSTGRES_PORT=5432

TEMPLATES_DIR=/code/client/templates
STATIC_DIR=/code/client/static

JWT_SECRET_KEY=replace-with-a-strong-random-secret
JWT_ALGORITHM=HS256
COOKIE_SECURE=false
LOG_DIR=/code/logs
APP_LOG_LEVEL=INFO
APP_LOG_MAX_BYTES=1048576
APP_LOG_BACKUP_COUNT=5

AVATAR_UPLOAD_DIR=client/static/uploads/avatars
MAX_AVATAR_SIZE_BYTES=2097152

JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
FORGOT_PASSWORD_RATE_LIMIT_MAX_ATTEMPTS=5
FORGOT_PASSWORD_RATE_LIMIT_WINDOW_SECONDS=300

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_google_account@gmail.com
SMTP_PASSWORD=your_google_app_password
SMTP_FROM_EMAIL=your_google_account@gmail.com
SMTP_FROM_NAME=IT-Support
SMTP_USE_TLS=true
MAIL_APP_NAME=Mail

POSTGRES_TEST_DB=app_test_db
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/diplom_test_db
