POSTGRES_DB=app_db
POSTGRES_USER=app_user
POSTGRES_PASSWORD=app_pass
POSTGRES_HOST=db
POSTGRES_PORT=5432

TEMPLATES_DIR=/code/client/templates
STATIC_DIR=/code/client/static

JWT_SECRET_KEY=replace-with-a-strong-random-secret
JWT_ALGORITHM=HS256
COOKIE_SECURE=false

AVATAR_UPLOAD_DIR=client/static/uploads/avatars
MAX_AVATAR_SIZE_BYTES=2097152

JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

POSTGRES_TEST_DB=app_test_db
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/diplom_test_db
